# Copy this file to .streamlit/secrets.toml and fill in your real values for local testing.
# secrets.toml is gitignored - never commit real keys.
# On Streamlit Community Cloud, paste these same values into your app's Settings -> Secrets
# instead of uploading this file.

SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY = "your-supabase-anon-public-key"
GROQ_API_KEY = "your-groq-api-key"
